# ============================================================
#  CI secrets —— ci-templates build-deploy 流水线用
#  用法:复制为 ci-secrets.env 填真实值(ci-secrets.env 已 gitignore,绝不入库),
#       交给 agent → 用 `gh secret set --repo <服务repo>` 批量配进各服务 repo。
#  注:zj1123581321 是个人账号,无 org secrets → 每个走流水线的服务 repo 各配一份。
#      canary 阶段先只配 ai-info 一个 repo,跑通再推广。
# ============================================================

# ── 你来填:阿里云 ACR(私有镜像仓库登录,push/pull 镜像用)──────
#   阿里云控制台 → 容器镜像服务 ACR → 访问凭证 → 用户名 + 设置固定密码
ACR_USERNAME=
ACR_PASSWORD=

# ── 你来填:Tailscale(GitHub runner 临时入内网才能 SSH 到 100.x 目标机)──
#   二选一:
#   路线 A(推荐,永久免轮换)· Tailscale 后台 → Settings → OAuth clients 建:
TS_OAUTH_CLIENT_ID=
TS_OAUTH_SECRET=
#   路线 B(只给 agent API token,它自动建 auth key + 配 ACL,~90 天需轮换)·
#   Tailscale 后台 → Settings → Keys → Generate API access token:
TS_API_KEY=

# ── 你来填:GitHub PAT(runner checkout private ci-templates 的部署脚本)──────
#   github.com/settings/personal-access-tokens/new → Only select repos: ci-templates,
#   权限 Contents: Read-only。agent 会把它配成 GitHub secret **CI_TEMPLATES_PAT**。
GH_PAT_TOKEN=

# ── agent 自动生成 / 收集,你不用填 ───────────────────────────
#   SSH_DEPLOY_KEY  ← agent ssh-keygen 生成专用部署私钥,公钥加到目标机
#   KNOWN_HOSTS     ← agent ssh-keyscan 收集目标机指纹
